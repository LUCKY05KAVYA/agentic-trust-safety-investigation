        "def policy_risk_node(state: InvestigationState) -> InvestigationState:\n",
        "    \"\"\"Node 3: Policy checking and risk assessment\"\"\"\n",
        "\n",
        "    listing = state.listing\n",
        "    prompt = f\"\"\"\n",
        "    Perform a detailed Trust & Safety analysis on this product listing.\n",
        "\n",
        "    Title: {listing.get('title')}\n",
        "    Description: {listing.get('description')}\n",
        "    Price: ₹{listing.get('price', 'N/A')}\n",
        "    Brand: {listing.get('brand', 'Unknown')}\n",
        "\n",
        "    Previous findings:\n",
        "    Inconsistencies: {state.inconsistencies}\n",
        "    Query Intent: {state.query_intent}\n",
        "\n",
        "    Identify all possible violations and assess overall risk.\n",
        "    \"\"\"\n",
        "\n",
        "    messages = [\n",
        "        SystemMessage(content=SYSTEM_PROMPT),\n",
        "        HumanMessage(content=prompt)\n",
        "    ]\n",
        "\n",
        "    response = llm.invoke(messages)\n",
        "    state.risk_analysis = response.content.strip()\n",
        "\n",
        "    # Simple violation extraction (can be improved later)\n",
        "    if \"leather\" in listing.get('description', '').lower() and state.inconsistencies:\n",
        "        state.violations.append(\"Misleading Material Claims\")\n",
        "    if \"counterfeit\" in response.content.lower() or \"fake\" in response.content.lower():\n",
        "        state.violations.append(\"Possible Counterfeit\")\n",
        "\n",
        "    state.violations = list(set(state.violations))  # remove duplicates\n",
        "\n",
        "    return state\n",
        "\n",
        "print(\"✅ Node 3 (Policy & Risk Analysis) created\")"

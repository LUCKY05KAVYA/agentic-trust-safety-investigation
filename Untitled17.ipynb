        "from langgraph.graph import StateGraph, END, START\n",
        "\n",
        "# Create the graph\n",
        "workflow = StateGraph(InvestigationState)\n",
        "\n",
        "# Add nodes\n",
        "workflow.add_node(\"understanding\", understanding_node)\n",
        "workflow.add_node(\"verification\", verification_node)\n",
        "workflow.add_node(\"policy_risk\", policy_risk_node)\n",
        "workflow.add_node(\"reflection\", reflection_node)\n",
        "workflow.add_node(\"decision\", decision_node)\n",
        "\n",
        "# Define the flow\n",
        "workflow.add_edge(START, \"understanding\")\n",
        "workflow.add_edge(\"understanding\", \"verification\")\n",
        "workflow.add_edge(\"verification\", \"policy_risk\")\n",
        "workflow.add_edge(\"policy_risk\", \"reflection\")\n",
        "workflow.add_edge(\"reflection\", \"decision\")\n",
        "workflow.add_edge(\"decision\", END)\n",
        "\n",
        "# Compile the graph\n",
        "agent = workflow.compile()\n",
        "\n",
        "print(\"✅ Full LangGraph compiled successfully!\")\n",
        "print(\"Agent is ready to run investigations\")"
      ],

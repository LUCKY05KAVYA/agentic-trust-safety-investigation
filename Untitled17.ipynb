        "def evaluate_agent(dataset: List[Dict], num_samples: int = None):\n",
        "    if num_samples is None:\n",
        "        num_samples = len(dataset)\n",
        "\n",
        "    results = []\n",
        "    total_time = 0\n",
        "    correct_decisions = 0\n",
        "    correct_violations = 0\n",
        "\n",
        "    print(f\"🚀 Starting Evaluation on {num_samples} samples...\\n\")\n",
        "\n",
        "    for item in dataset[:num_samples]:\n",
        "        start_time = time.time()\n",
        "\n",
        "        initial_state = InvestigationState(listing={\n",
        "            \"title\": item[\"title\"],\n",
        "            \"description\": item[\"description\"],\n",
        "            \"price\": item[\"price\"],\n",
        "            \"brand\": item[\"brand\"],\n",
        "            \"image_paths\": item.get(\"image_paths\", [])\n",
        "        })\n",
        "\n",
        "        final_state = agent.invoke(initial_state)\n",
        "\n",
        "        # Handle dict or object\n",
        "        state_dict = final_state if isinstance(final_state, dict) else final_state.dict() if hasattr(final_state, 'dict') else final_state.__dict__\n",
        "        decision = state_dict.get('final_decision', {})\n",
        "\n",
        "        latency = time.time() - start_time\n",
        "        total_time += latency\n",
        "\n",
        "        predicted_risk = decision.get('risk_level', 'Low')\n",
        "        gt_risk = item['ground_truth']['risk_level']\n",
        "\n",
        "        if predicted_risk == gt_risk:\n",
        "            correct_decisions += 1\n",
        "\n",
        "        # Simple violation match\n",
        "        pred_violations = set(decision.get('violations', []))\n",
        "        gt_violations = set(item['ground_truth']['violations'])\n",
        "        if len(pred_violations.intersection(gt_violations)) >= len(gt_violations) * 0.5:\n",
        "            correct_violations += 1\n",
        "\n",
        "        results.append({\n",
        "            \"id\": item[\"id\"],\n",
        "            \"predicted_risk\": predicted_risk,\n",
        "            \"actual_risk\": gt_risk,\n",
        "            \"latency\": round(latency, 2),\n",
        "            \"correct\": predicted_risk == gt_risk\n",
        "        })\n",
        "\n",
        "    # Calculate Metrics\n",
        "    accuracy = (correct_decisions / num_samples) * 100\n",
        "    violation_f1_approx = (correct_violations / num_samples) * 100\n",
        "    avg_latency = total_time / num_samples\n",
        "\n",
        "    print(\"=== EVALUATION RESULTS ===\")\n",
        "    print(f\"Decision Accuracy     : {accuracy:.1f}%\")\n",
        "    print(f\"Violation Detection   : {violation_f1_approx:.1f}%\")\n",
        "    print(f\"Average Latency       : {avg_latency:.2f} seconds\")\n",
        "    print(f\"Total Samples         : {num_samples}\")\n",
        "    print(f\"Simulated Manual Review Reduction : ~{int(accuracy * 0.7)}%\")  # rough estimate\n",
        "\n",
        "    return results\n",
        "\n",
        "print(\"✅ Evaluation framework ready\")"
      ],
